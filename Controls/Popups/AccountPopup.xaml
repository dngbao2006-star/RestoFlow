<?xml version="1.0" encoding="utf-8" ?>
<!--
    AccountPopup.xaml

    THAY ĐỔI: Đã xoá HorizontalOptions="End" VerticalOptions="Start" (sai mục đích).
    Vị trí bên dưới nút tài khoản được xử lý bởi Anchor trong AppHeaderView.xaml.cs.
    Dim được xử lý bởi NoDimPopupHandler.cs.
-->
<toolkit:Popup
    x:Class="AppManagermentRestaurant.Controls.Popups.AccountPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Color="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        BackgroundColor="#FDFAF6"
        Stroke="#E7DECF"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 16"
        Padding="0"
        WidthRequest="224"
        Shadow="{Shadow Brush=Black, Offset='0,8', Radius=20, Opacity=0.18}">

        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0">

            <!-- Header: tên + email -->
            <Grid Grid.Row="0" Padding="16" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                <Label
                    Text="{Binding CurrentUserName}"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#1A1209" />
                <Label
                    Grid.Row="1"
                    Text="{Binding CurrentUserEmail}"
                    FontSize="12"
                    TextColor="#7B6A57" />
                <BoxView
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    HeightRequest="1"
                    Color="#EFE4D5" />
            </Grid>

            <!-- Nút Tài khoản -->
            <Button
                Grid.Row="1"
                Text="👤  Tài khoản"
                FontSize="14"
                TextColor="#3D2C1E"
                HorizontalOptions="Fill"
                BackgroundColor="Transparent"
                Padding="16,12"
                Clicked="OnProfileClicked">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal" />
                            <VisualState Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#F3EEE8" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#EDE8DC" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

            <BoxView HeightRequest="1" Color="#EFE4D5" Grid.Row="1" VerticalOptions="End" />

            <!-- Nút Đăng xuất -->
            <Button
                Grid.Row="2"
                Text="↪  Đăng xuất"
                FontSize="14"
                TextColor="#EF4444"
                HorizontalOptions="Fill"
                BackgroundColor="Transparent"
                Padding="16,12"
                Clicked="OnLogoutClicked">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal" />
                            <VisualState Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FFF7F7" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#FFF1F1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>
        </Grid>
    </Border>
</toolkit:Popup>
