<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppManagermentRestaurant.Controls.LoadingIndicator">

    <Grid RowDefinitions="Auto,Auto" 
          RowSpacing="12"
          Padding="20"
          VerticalOptions="Center"
          HorizontalOptions="Center"
          IsVisible="False">

        <!-- Loading Spinner -->
        <ActivityIndicator 
            IsRunning="{Binding IsLoading, Source={RelativeSource AncestorType={x:Type ContentView}}}"
            IsVisible="{Binding IsLoading, Source={RelativeSource AncestorType={x:Type ContentView}}}"
            Color="{StaticResource Primary}"
            Scale="1.5" />

        <!-- Loading Message -->
        <Label 
            x:Name="LoadingMessageLabel"
            Grid.Row="1"
            Text="Loading..."
            TextColor="{StaticResource TextSecondary}"
            FontSize="14"
            HorizontalOptions="Center"
            SemanticProperties.Description="Loading indicator" />

    </Grid>

</ContentView>
