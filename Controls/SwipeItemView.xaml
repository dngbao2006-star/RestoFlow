<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppManagermentRestaurant.Controls.SwipeItemView">

    <SwipeView>
        <!-- Left Swipe (Edit) -->
        <SwipeView.LeftItems>
            <SwipeItems Mode="Reveal">
                <SwipeItem BackgroundColor="#FF9500" Command="{Binding EditCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}">
                    <SwipeItem.IconImageSource>
                        <FontImageSource 
                            Glyph="✎"
                            Color="White" />
                    </SwipeItem.IconImageSource>
                </SwipeItem>
            </SwipeItems>
        </SwipeView.LeftItems>

        <!-- Right Swipe (Delete) -->
        <SwipeView.RightItems>
            <SwipeItems Mode="Reveal">
                <SwipeItem BackgroundColor="#EF4444" Command="{Binding DeleteCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}">
                    <SwipeItem.IconImageSource>
                        <FontImageSource 
                            Glyph="🗑"
                            Color="White" />
                    </SwipeItem.IconImageSource>
                </SwipeItem>
            </SwipeItems>
        </SwipeView.RightItems>

        <!-- Main Content -->
        <Grid x:Name="ContentContainer">
            <!-- Content will be added here -->
        </Grid>
    </SwipeView>

</ContentView>
