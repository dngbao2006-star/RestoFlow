<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppManagermentRestaurant.Controls.AvatarView">

    <Grid WidthRequest="40" HeightRequest="40">
        <!-- Image Avatar -->
        <Image 
            x:Name="AvatarImage"
            Aspect="AspectFill"
            IsVisible="False" />

        <!-- Initials Avatar -->
        <Border 
            x:Name="InitialsBorder"
            Background="{StaticResource Primary}"
            Stroke="{StaticResource BorderLight}"
            StrokeThickness="1">
            <Label 
                x:Name="InitialsLabel"
                Text="AB"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>

        <!-- Status Indicator (if needed) -->
        <Ellipse 
            x:Name="StatusIndicator"
            Fill="{StaticResource Success}"
            WidthRequest="12"
            HeightRequest="12"
            Margin="0,-4,-4,0"
            HorizontalOptions="End"
            VerticalOptions="Start"
            IsVisible="False" />
    </Grid>

</ContentView>
