<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppManagermentRestaurant.Controls.StepProgressIndicator">

    <VerticalStackLayout Spacing="12" Padding="0">
        
        <!-- Progress Bar -->
        <ProgressBar x:Name="ProgressBar"
                     Progress="0"
                     ProgressColor="{StaticResource Primary}"
                     HeightRequest="4" />

        <!-- Step Indicators -->
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <CollectionView ItemsSource="{Binding StepLabels, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                           SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand">
                            <Border Background="{Binding IsComplete, Converter={StaticResource HasValueConverter}, ConverterParameter=Primary}"
                                    Stroke="{StaticResource Primary}"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="8,4"
                                    HorizontalOptions="Center">
                                <Label Text="{Binding StepNumber}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                            </Border>
                            <Label Text="{Binding Title}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentView>
