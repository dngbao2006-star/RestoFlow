<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppManagermentRestaurant.Controls.EmptyStateView">

    <VerticalStackLayout 
        Spacing="16"
        Padding="20"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <!-- Icon -->
        <Label 
            x:Name="IconLabel"
            Text="📭"
            FontSize="64"
            HorizontalOptions="Center"
            Margin="0,20,0,0" />

        <!-- Title -->
        <Label 
            x:Name="TitleLabel"
            Text="No Data Available"
            FontSize="20"
            FontAttributes="Bold"
            TextColor="{StaticResource TextPrimary}"
            HorizontalTextAlignment="Center"
            SemanticProperties.HeadingLevel="Level2" />

        <!-- Description -->
        <Label 
            x:Name="DescriptionLabel"
            Text=""
            FontSize="14"
            TextColor="{StaticResource TextSecondary}"
            HorizontalTextAlignment="Center"
            LineBreakMode="WordWrap"
            IsVisible="False" />

        <!-- Action Button -->
        <Button 
            Text="{Binding ActionText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
            Command="{Binding ActionCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}"
            Style="{StaticResource PrimaryButton}"
            IsVisible="False"
            Margin="0,12,0,0" />

    </VerticalStackLayout>

</ContentView>
