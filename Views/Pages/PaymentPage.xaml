<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppManagermentRestaurant.Views.Pages.PaymentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AppManagermentRestaurant.Controls"
    xmlns:helpers="clr-namespace:AppManagermentRestaurant.Helpers"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <helpers:HasValueConverter x:Key="HasValueConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*" ColumnSpacing="20">
        <controls:AppHeaderView Grid.ColumnSpan="2" />

        <ScrollView Grid.Row="1" Grid.Column="0">
            <VerticalStackLayout Padding="24" Spacing="20">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Chọn bàn cần thanh toán" FontAttributes="Bold" FontSize="14" />

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasBillableTables}">

                        <Border Stroke="#6366F1" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="White" HorizontalOptions="Start" WidthRequest="340" HeightRequest="42" Padding="0">
                            <Grid>
                                <Picker x:Name="TablePicker"
                                        ItemsSource="{Binding ActiveOrders}"
                                        ItemDisplayBinding="{Binding TableNumber, StringFormat='Bàn {0}'}"
                                        SelectedItem="{Binding SelectedTableOrder}"
                                        TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        FontAttributes="Bold" 
                                        VerticalOptions="FillAndExpand"
                                        HorizontalOptions="FillAndExpand"
                                        Margin="24,0,24,0"/>

                                <Grid ColumnDefinitions="Auto,*,Auto" InputTransparent="True" Padding="12,0">
                                    <Ellipse Grid.Column="0" Fill="#22C55E" WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="▼" FontSize="11" TextColor="#6B7280" VerticalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasSelectedOrder}" Padding="16" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="8">
                                <VerticalStackLayout Spacing="4" Grid.Column="0">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="📍" FontSize="14" VerticalOptions="Center" />
                                        <Label Text="{Binding SelectedTableOrder.TableNumber, StringFormat='Bàn số {0}'}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Primary}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="👨‍💼" FontSize="12" VerticalOptions="Center" />
                                        <Label Text="{Binding SelectedTableOrder.ServerName}" Style="{StaticResource SecondaryTextStyle}" FontSize="11" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="Tổng tiền" Style="{StaticResource MutedTextStyle}" FontSize="10" HorizontalOptions="End" />
                                    <Label Text="{Binding SelectedTableOrder.TotalDisplay}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Label Text="Không có bàn nào cần thanh toán" Style="{StaticResource MutedTextStyle}" HorizontalOptions="Center" IsVisible="{Binding HasBillableTables, Converter={StaticResource BoolNegationConverter}}" />
                </VerticalStackLayout>

                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasSelectedOrder}">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="Hóa Đơn Thanh Toán" FontFamily="{StaticResource DisplayFont}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                            <Label Text="Classic Restaurant" FontFamily="{StaticResource DisplayFont}" FontSize="16" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                            <Label Text="Quận 1, TP. Hồ Chí Minh | Hotline: 0900 999 888" Style="{StaticResource SecondaryTextStyle}" FontSize="11" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />

                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Label Text="Bàn:" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedTableOrder.TableNumber, StringFormat='• {0}'}" FontAttributes="Bold" TextColor="{StaticResource Primary}" FontSize="16" />
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />

                        <Label Text="Danh sách món ăn" FontAttributes="Bold" FontSize="12" />
                        <CollectionView ItemsSource="{Binding SelectedTableOrder.Items}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="8,4" ColumnSpacing="12" RowSpacing="2">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="13" />
                                            <Label Text="{Binding Notes}" Style="{StaticResource MutedTextStyle}" FontSize="9" IsVisible="{Binding Notes, Converter={StaticResource HasValueConverter}}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" Style="{StaticResource SecondaryTextStyle}" FontSize="12" VerticalOptions="Center" />
                                        <Label Grid.Column="2" Text="{Binding LineTotalDisplay}" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" HorizontalOptions="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />

                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Cộng tiền hàng:" Style="{StaticResource SecondaryTextStyle}" />
                                <Label Grid.Column="1" Text="{Binding SelectedTableOrder.Subtotal, StringFormat='{0:0,0} đ'}" FontAttributes="Bold" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding SelectedTableOrder.HasDiscount}">
                                <Label Grid.Column="0" Text="Giảm giá:" Style="{StaticResource SecondaryTextStyle}" TextColor="{StaticResource Success}" />
                                <Label Grid.Column="1" Text="{Binding DiscountDisplay, StringFormat='- {0}'}" TextColor="{StaticResource Success}" FontAttributes="Bold" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" IsVisible="{Binding SelectedTableOrder.HasDiscount}" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Tổng cộng:" FontAttributes="Bold" FontSize="16" />
                                <Label Grid.Column="1" Text="{Binding SelectedTableOrder.TotalDisplay}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" />
                            </Grid>
                        </VerticalStackLayout>

                        <Border Style="{StaticResource InputBorder}" BackgroundColor="#F5F5F5" Padding="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Áp dụng mã giảm giá" FontAttributes="Bold" FontSize="12" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Entry Grid.Column="0" x:Name="DiscountCodeEntry" Placeholder="Nhập mã giảm giá" BackgroundColor="Transparent" />
                                    <Button Grid.Column="1" Text="Áp dụng" Style="{StaticResource SecondaryButton}" Clicked="OnApplyDiscountClicked" Padding="12,8" FontSize="13" />
                                </Grid>
                                <Label x:Name="DiscountErrorLabel" TextColor="{StaticResource Danger}" IsVisible="False" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="1" Grid.Column="1" IsVisible="{Binding HasSelectedOrder}">
            <VerticalStackLayout Padding="24" Spacing="20">
                <Label Text="Phương thức thanh toán" Style="{StaticResource SectionTitle}" FontSize="20" />

                <VerticalStackLayout Spacing="12">
                    <Border Stroke="{StaticResource BorderLight}" StrokeThickness="2" Padding="16" StrokeShape="RoundRectangle 12" Background="{StaticResource Surface}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaymentMethodTapped" CommandParameter="QR" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="💳" FontSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="Thanh toán QR" FontAttributes="Bold" FontSize="14" />
                                <Label Text="Quét mã QR để chuyển khoản" Style="{StaticResource SecondaryTextStyle}" FontSize="11" />
                            </VerticalStackLayout>
                            <BoxView IsVisible="{Binding IsQRSelected}" WidthRequest="24" HeightRequest="24" CornerRadius="12" Background="{StaticResource Success}" HorizontalOptions="EndAndExpand" />
                            <Label Text="✓" FontSize="20" TextColor="{StaticResource Success}" HorizontalOptions="EndAndExpand" IsVisible="{Binding IsQRSelected}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border Stroke="{StaticResource BorderLight}" StrokeThickness="2" Padding="16" StrokeShape="RoundRectangle 12" Background="{StaticResource Surface}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaymentMethodTapped" CommandParameter="Cash" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Label Text="💵" FontSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="Thanh toán tiền mặt" FontAttributes="Bold" FontSize="14" />
                                <Label Text="Thanh toán trực tiếp bằng tiền mặt" Style="{StaticResource SecondaryTextStyle}" FontSize="11" />
                            </VerticalStackLayout>
                            <BoxView IsVisible="{Binding IsCashSelected}" WidthRequest="24" HeightRequest="24" CornerRadius="12" Background="{StaticResource Success}" HorizontalOptions="EndAndExpand" />
                            <Label Text="✓" FontSize="20" TextColor="{StaticResource Success}" HorizontalOptions="EndAndExpand" IsVisible="{Binding IsCashSelected}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding IsQRSelected}">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Mã QR thanh toán" FontAttributes="Bold" FontSize="16" />
                        <Border Background="{StaticResource Surface}" Stroke="{StaticResource BorderLight}" StrokeThickness="2" StrokeShape="RoundRectangle 12" Padding="24" HorizontalOptions="Center" WidthRequest="280" HeightRequest="280">
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="[QR CODE]" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="32" />
                                <Label Text="Mã QR được tạo tự động" HorizontalOptions="Center" Style="{StaticResource MutedTextStyle}" FontSize="10" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource InputBorder}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Thông tin chuyển khoản" FontAttributes="Bold" FontSize="12" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0" Text="🏦" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                        <Label Text="Ngân hàng:" FontAttributes="Bold" />
                                        <Label Text="Vietcombank" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Grid.Column="0" Text="🏷️" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                        <Label Text="Số tài khoản:" FontAttributes="Bold" />
                                        <Label Text="1024688888" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="2" Grid.Column="0" Text="👤" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                        <Label Text="Chủ tài khoản:" FontAttributes="Bold" />
                                        <Label Text="Nhà hàng Dĩa Vàng" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" Margin="0,4" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="💰" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                        <Label Text="Số tiền:" FontAttributes="Bold" />
                                        <Label Text="{Binding SelectedTableOrder.TotalDisplay}" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <Label Text="{Binding TransferContent}" Style="{StaticResource MutedTextStyle}" FontSize="10" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Button Text="✓ Xác nhận thanh toán" Style="{StaticResource PrimaryButton}" Clicked="OnConfirmPaymentClicked" IsEnabled="{Binding CanConfirmPayment}" Padding="16,14" FontSize="16" FontAttributes="Bold" BackgroundColor="#1E3A8A" TextColor="White" />
            </VerticalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="1" Grid.Column="1" IsVisible="{Binding HasSelectedOrder, Converter={StaticResource BoolNegationConverter}}">
            <VerticalStackLayout Padding="24" Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label Text="👈" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Vui lòng chọn một bàn từ danh sách bên trái" Style="{StaticResource MutedTextStyle}" HorizontalTextAlignment="Center" />
                    <Label Text="để xem phương thức thanh toán" Style="{StaticResource MutedTextStyle}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>