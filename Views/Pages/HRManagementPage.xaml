<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppManagermentRestaurant.Views.Pages.HRManagementPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AppManagermentRestaurant.Controls"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <controls:AppHeaderView />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

            <!-- ════════════════════════════════════════════════════ -->
            <!--  LEFT: STAFF LIST (full width when no detail)      -->
            <!-- ════════════════════════════════════════════════════ -->
            <ScrollView>
                <VerticalStackLayout Padding="24" Spacing="20">

                    <!-- Header -->
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <Label Text="Quản lý nhân sự" Style="{StaticResource PageTitle}" />
                        <Button Text="+ Thêm nhân viên"
                                Clicked="OnAddEmployeeClicked"
                                Style="{StaticResource PrimaryButton}" />
                    </HorizontalStackLayout>

                    <!-- Statistics Cards -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                        <Border Style="{StaticResource CardBorder}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tổng nhân sự" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding TotalStaff}" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Grid.Column="1">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Đang hoạt động" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding ActiveStaff}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Grid.Column="2">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Quản lý" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding ManagerCount}" FontSize="24" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Grid.Column="3">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Đã khóa" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding LockedStaff}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Danger}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Search Only -->
                    <Border Style="{StaticResource InputBorder}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Text="🔍" VerticalOptions="Center" FontSize="16" />
                            <Entry Grid.Column="1"
                                   Placeholder="Tìm theo tên hoặc email..."
                                   Text="{Binding SearchText}"
                                   FontSize="14" />
                            <Button Grid.Column="2"
                                    Text="✕"
                                    Clicked="OnClearSearchClicked"
                                    Background="Transparent"
                                    TextColor="{StaticResource TextMuted}"
                                    Padding="0"
                                    WidthRequest="40"
                                    HeightRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Staff Count -->
                    <Label Text="{Binding FilteredStaff.Count, StringFormat='Hiển thị {0} nhân sự'}"
                           FontSize="12" TextColor="{StaticResource TextMuted}" FontAttributes="Bold" />

                    <!-- Staff List -->
                    <CollectionView ItemsSource="{Binding FilteredStaff}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}"
                                        Margin="0,0,0,12"
                                        Padding="16">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                        <!-- Avatar -->
                                        <Border Background="{StaticResource PrimaryAccent}"
                                                Stroke="{StaticResource BorderLight}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="12"
                                                WidthRequest="48"
                                                HeightRequest="48">
                                            <Label Text="{Binding Initials}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>

                                        <!-- Info -->
                                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="4">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14" />
                                            <Label Text="{Binding Email}" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                            <Label Text="{Binding Phone}" FontSize="11" TextColor="{StaticResource TextMuted}" />
                                            <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                                                <Border Style="{StaticResource BadgeBorder}">
                                                    <Label Text="{Binding RoleLabel}" Style="{StaticResource BadgeText}" FontSize="10" />
                                                </Border>
                                                <Border Style="{StaticResource BadgeBorder}"
                                                        BackgroundColor="{Binding Status, Converter={StaticResource StatusColorConverter}}">
                                                    <Label Text="{Binding StatusLabel}" Style="{StaticResource BadgeText}" FontSize="10" />
                                                </Border>
                                                <Border Style="{StaticResource BadgeBorder}" Padding="8,2">
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsOnline}" Value="True">
                                                            <Setter Property="BackgroundColor" Value="#22C55E" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsOnline}" Value="False">
                                                            <Setter Property="BackgroundColor" Value="#9CA3AF" />
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Label Text="{Binding OnlineStatus}" Style="{StaticResource BadgeText}" FontSize="10" />
                                                </Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Single "Chi tiết" button -->
                                        <Button Grid.Column="2"
                                                Text="Chi tiết"
                                                Clicked="OnViewStaffClicked"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="14,8"
                                                FontSize="12"
                                                VerticalOptions="Center" />

                                        <!-- Last Login -->
                                        <Label Grid.Row="1" Grid.ColumnSpan="3"
                                               Text="{Binding LastLogin, StringFormat='Đăng nhập gần nhất: {0:g}'}"
                                               FontSize="10"
                                               TextColor="{StaticResource TextMuted}"
                                               Margin="0,8,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ════════════════════════════════════════════════════ -->
            <!--  RIGHT: STAFF DETAIL PANEL (appears on click)     -->
            <!-- ════════════════════════════════════════════════════ -->
            <Border Grid.Column="1"
                    IsVisible="{Binding ShowStaffDetails}"
                    Background="#F8F9FA"
                    StrokeThickness="0"
                    WidthRequest="380">

                <ScrollView Padding="20">
                    <VerticalStackLayout Spacing="16">

                        <!-- Header -->
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Start">
                            <Label Text="Chi tiết nhân sự" FontAttributes="Bold" FontSize="16" />
                            <Button Text="✕"
                                    Clicked="OnCloseDetailsClicked"
                                    Background="Transparent"
                                    TextColor="{StaticResource TextMuted}"
                                    Padding="0"
                                    HorizontalOptions="EndAndExpand"
                                    WidthRequest="32"
                                    HeightRequest="32" />
                        </HorizontalStackLayout>

                        <!-- Staff Info Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="16">
                            <VerticalStackLayout Spacing="14">
                                <!-- Avatar -->
                                <Border Background="{StaticResource PrimaryAccent}"
                                        Stroke="{StaticResource BorderLight}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 30"
                                        Padding="20"
                                        WidthRequest="80"
                                        HeightRequest="80"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding SelectedStaff.Initials}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="32"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>

                                <!-- Name -->
                                <Label Text="{Binding SelectedStaff.Name}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalTextAlignment="Center" />

                                <!-- Details Grid -->
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12" RowSpacing="10"
                                      Padding="4,8">

                                    <Label Grid.Row="0" Grid.Column="0" Text="Họ và tên:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedStaff.Name}" FontSize="12" VerticalOptions="Center" />

                                    <Label Grid.Row="1" Grid.Column="0" Text="Vai trò:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Border Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource BadgeBorder}"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding SelectedStaff.RoleLabel}" Style="{StaticResource BadgeText}" FontSize="10" />
                                    </Border>

                                    <Label Grid.Row="2" Grid.Column="0" Text="Điện thoại:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedStaff.Phone}" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource TextMuted}" />

                                    <Label Grid.Row="3" Grid.Column="0" Text="Email:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedStaff.Email}" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource TextMuted}" LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="4" Grid.Column="0" Text="Ngày vào làm:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedStaff.JoinDate, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" VerticalOptions="Center" />

                                    <Label Grid.Row="5" Grid.Column="0" Text="Trạng thái:" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                                    <Border Grid.Row="5" Grid.Column="1"
                                            Style="{StaticResource BadgeBorder}"
                                            BackgroundColor="{Binding SelectedStaff.Status, Converter={StaticResource StatusColorConverter}}"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding SelectedStaff.StatusLabel}" Style="{StaticResource BadgeText}" FontSize="10" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Action Buttons (Edit only for Staff role) -->
                        <VerticalStackLayout Spacing="8">
                            <Button x:Name="BtnEditStaff"
                                    Text="✏️ Chỉnh sửa"
                                    Clicked="OnEditStaffClicked"
                                    Style="{StaticResource PrimaryButton}" />
                            <Button Text="🗑️ Xóa nhân sự"
                                    Clicked="OnDeleteStaffClicked"
                                    Style="{StaticResource DangerButton}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <!-- ════════════════════════════════════════════════════ -->
            <!--  EDIT STAFF MODAL (overlay)                        -->
            <!-- ════════════════════════════════════════════════════ -->
            <Grid x:Name="EditStaffModal"
                  Grid.ColumnSpan="2"
                  IsVisible="False"
                  Background="#80000000"
                  InputTransparent="False">

                <Border Background="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Margin="120,60"
                        Padding="0"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        WidthRequest="480">

                    <VerticalStackLayout Spacing="0">

                        <!-- Modal Header -->
                        <Grid Padding="24,20"
                              ColumnDefinitions="*,Auto"
                              Background="#F9FAFB">
                            <Label Text="✏️ Chỉnh sửa thông tin nhân viên"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1E3A5F"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    Background="#FEE2E2"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCloseEditModalTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="✕"
                                       TextColor="#EF4444"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <!-- Modal Body -->
                        <VerticalStackLayout Padding="24" Spacing="16">

                            <!-- Email -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Email" FontAttributes="Bold" FontSize="12" TextColor="#6B7280" />
                                <Border Style="{StaticResource InputBorder}" Padding="12,8">
                                    <Entry x:Name="EditEmail"
                                           Placeholder="Nhập email..."
                                           FontSize="14"
                                           Keyboard="Email" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Số điện thoại" FontAttributes="Bold" FontSize="12" TextColor="#6B7280" />
                                <Border Style="{StaticResource InputBorder}" Padding="12,8">
                                    <Entry x:Name="EditPhone"
                                           Placeholder="Nhập số điện thoại..."
                                           FontSize="14"
                                           Keyboard="Telephone" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Join Date -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Ngày vào làm" FontAttributes="Bold" FontSize="12" TextColor="#6B7280" />
                                <Border Style="{StaticResource InputBorder}" Padding="12,8">
                                    <DatePicker x:Name="EditJoinDate"
                                                FontSize="14"
                                                Format="dd/MM/yyyy" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Status Toggle -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Trạng thái tài khoản" FontAttributes="Bold" FontSize="12" TextColor="#6B7280" />
                                <Border Style="{StaticResource InputBorder}" Padding="12,8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <Label x:Name="EditStatusLabel"
                                               Text="Hoạt động"
                                               FontSize="14"
                                               VerticalOptions="Center" />
                                        <Switch x:Name="EditStatusSwitch"
                                                Grid.Column="1"
                                                OnColor="#22C55E"
                                                ThumbColor="White"
                                                Toggled="OnStatusToggled"
                                                VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                        <!-- Modal Footer -->
                        <Grid Padding="24,12,24,20"
                              ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Button Text="Hủy"
                                    Clicked="OnCloseEditModalTapped"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Grid.Column="1"
                                    Text="💾 Lưu thay đổi"
                                    Clicked="OnSaveEditClicked"
                                    Style="{StaticResource PrimaryButton}" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>
