<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppManagermentRestaurant.Views.Pages.AddMenuItemPage"
    x:Name="MenuItemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AppManagermentRestaurant.Controls"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <controls:AppHeaderView />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="20">

                <!-- Title -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Thêm Món Ăn" Style="{StaticResource PageTitle}" IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    <Label Text="Sửa Món Ăn" Style="{StaticResource PageTitle}" IsVisible="{Binding IsEditing}" />
                    <Label 
                        Text="{Binding Name}"
                        FontSize="14"
                        TextColor="{StaticResource TextMuted}"
                        IsVisible="{Binding IsEditing}" />
                </VerticalStackLayout>

                <!-- Form Error Banner (On-submit) -->
                <Border 
                    Background="#FFF3E0" Stroke="#FF9800" StrokeThickness="1" 
                    StrokeShape="RoundRectangle 8" Padding="12"
                    IsVisible="{Binding HasFormError}">
                    <Label Text="{Binding FormError}" TextColor="#E65100" FontAttributes="Bold" FontSize="13" />
                </Border>

                <!-- Image Section (Optional) -->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Ảnh món ăn" FontAttributes="Bold" />
                        <Label Text="Không bắt buộc — nếu trống sẽ hiển thị ảnh mặc định" 
                               FontSize="11" TextColor="{StaticResource TextMuted}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Link ảnh (URL)" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource TextMuted}" />
                            <Border Style="{StaticResource InputBorder}">
                                <Entry 
                                    x:Name="ImageUrlEntry"
                                    Text="{Binding ImageUrl}" 
                                    Placeholder="https://example.com/image.jpg"
                                    FontSize="12" />
                            </Border>
                        </VerticalStackLayout>

                        <Frame BorderColor="{StaticResource BorderColor}" CornerRadius="10" Padding="0" HasShadow="False">
                            <Grid HeightRequest="200" BackgroundColor="#F5F5F5">
                                <Image 
                                    Source="{Binding ImageUrl}" 
                                    Aspect="AspectFill"
                                    IsVisible="{Binding ImageUrl, Converter={StaticResource HasValueConverter}}" />
                                <VerticalStackLayout 
                                    Spacing="8" 
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding ImageUrl, Converter={StaticResource BooleanNegationConverter}, ConverterParameter={StaticResource HasValueConverter}}">
                                    <Label Text="🖼️" FontSize="48" HorizontalOptions="Center" />
                                    <Label Text="Xem trước ảnh" HorizontalOptions="Center" TextColor="{StaticResource TextMuted}" />
                                    <Label Text="Nhập link ảnh để xem" HorizontalOptions="Center" FontSize="11" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Border>

                <!-- Basic Information -->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Thông tin cơ bản" FontAttributes="Bold" />

                        <!-- Name (Bắt buộc) -->
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="Tên món ăn" FontAttributes="Bold" />
                                <Label Text="*" TextColor="#F44336" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <Border Style="{StaticResource InputBorder}" 
                                    Stroke="{Binding HasNameError, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Error}">
                                <Entry 
                                    x:Name="NameEntry"
                                    Text="{Binding Name}" 
                                    Placeholder="Nhập tên món ăn"
                                    Unfocused="OnNameUnfocused" />
                            </Border>
                            <Label Text="{Binding NameError}" TextColor="#F44336" FontSize="11" IsVisible="{Binding HasNameError}" />
                        </VerticalStackLayout>

                        <!-- Category (Bắt buộc) -->
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="Danh mục" FontAttributes="Bold" />
                                <Label Text="*" TextColor="#F44336" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <CollectionView ItemsSource="{Binding Categories}" SelectionMode="Single" SelectedItem="{Binding Category}">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border 
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,8">
                                            <Border.Stroke>
                                                <MultiBinding Converter="{StaticResource CategorySelectedConverter}">
                                                    <Binding Path="." />
                                                    <Binding Path="BindingContext.Category" Source="{x:Reference MenuItemPage}" />
                                                </MultiBinding>
                                            </Border.Stroke>
                                            <Border.Background>
                                                <MultiBinding Converter="{StaticResource CategoryBackgroundConverter}">
                                                    <Binding Path="." />
                                                    <Binding Path="BindingContext.Category" Source="{x:Reference MenuItemPage}" />
                                                </MultiBinding>
                                            </Border.Background>
                                            <Label 
                                                Text="{Binding .}" 
                                                FontAttributes="Bold"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer 
                                                        Command="{Binding Source={x:Reference MenuItemPage}, Path=BindingContext.SelectCategoryCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Label Text="{Binding CategoryError}" TextColor="#F44336" FontSize="11" IsVisible="{Binding HasCategoryError}" />
                        </VerticalStackLayout>

                        <!-- Price (Bắt buộc) -->
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="Giá (VND)" FontAttributes="Bold" />
                                <Label Text="*" TextColor="#F44336" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <Border Style="{StaticResource InputBorder}"
                                    Stroke="{Binding HasPriceError, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Error}">
                                <Entry 
                                    x:Name="PriceEntry"
                                    Text="{Binding Price, StringFormat='{0:F0}'}" 
                                    Placeholder="0"
                                    Keyboard="Numeric"
                                    Unfocused="OnPriceUnfocused" />
                            </Border>
                            <Label Text="{Binding PriceError}" TextColor="#F44336" FontSize="11" IsVisible="{Binding HasPriceError}" />
                        </VerticalStackLayout>

                        <!-- Description (Không bắt buộc) -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mô tả" FontAttributes="Bold" />
                            <Label Text="Không bắt buộc" FontSize="11" TextColor="{StaticResource TextMuted}" />
                            <Border Style="{StaticResource InputBorder}">
                                <Editor 
                                    Text="{Binding Description}" 
                                    Placeholder="Nhập mô tả món ăn"
                                    HeightRequest="100" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Status Section — Single Toggle -->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Trạng thái" FontAttributes="Bold" />

                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Switch IsToggled="{Binding IsServing}" />
                            <Label Text="{Binding StatusLabel}" 
                                   FontAttributes="Bold" FontSize="14"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Action Buttons -->
                <HorizontalStackLayout Spacing="12">
                    <Button 
                        Text="Hủy" 
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnCancelClicked"
                        HorizontalOptions="FillAndExpand" />
                    <Button 
                        x:Name="SaveButton"
                        Text="Lưu" 
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnSaveClicked"
                        IsEnabled="{Binding CanSave}"
                        HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>

                <!-- Loading Indicator -->
                <controls:LoadingIndicator IsVisible="{Binding IsLoading}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
