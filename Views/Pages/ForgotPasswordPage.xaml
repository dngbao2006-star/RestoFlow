<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Class="AppManagermentRestaurant.Views.Pages.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="*,*">

        <Grid Grid.Column="0" IsVisible="{OnIdiom Phone=False, Default=True}">

            <Image Source="anhnenlogin.jpg"
                   Aspect="AspectFill"/>

            <BoxView Background="#661B3A6B"/>

            <VerticalStackLayout Padding="40"
                                 Spacing="16"
                                 VerticalOptions="Center">

                <Label Text="Đặt lại mật khẩu"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="Chúng tôi đã gửi một đường link để reset mật khẩu vào email của bạn"
                       TextColor="#E9EEF8"/>

            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Column="1" BackgroundColor="White">
            <ScrollView>
                <VerticalStackLayout Padding="40" Spacing="20"
                                     VerticalOptions="Center">

                    <Label Text="Quên mật khẩu"
                           FontSize="28"
                           FontAttributes="Bold"/>

                    <Label Text="Nhập email của bạn để nhận đường link đặt lại mật khẩu"
                           TextColor="Gray"/>

                    <Border Stroke="#DDD"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                        <Entry x:Name="EmailEntry" 
                               Placeholder="Địa chỉ email"
                               Keyboard="Email"/>
                    </Border>

                    <Button Text="Gửi đường link đặt lại mật khẩu"
                            BackgroundColor="#1B3A6B"
                            TextColor="White"
                            CornerRadius="12"
                            Clicked="OnSendResetClicked"/>

                    <Button Text="Quay lại đăng nhập"
                            BackgroundColor="Transparent"
                            TextColor="#1B3A6B"
                            Clicked="OnBackClicked"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>