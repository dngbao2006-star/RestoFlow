<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Class="AppManagermentRestaurant.Views.Pages.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="*,*">

        <!-- ===== LEFT (GIỐNG LOGIN) ===== -->
        <Grid Grid.Column="0" IsVisible="{OnIdiom Phone=False, Default=True}">

            <Image Source="anhnenlogin.jpg"
                   Aspect="AspectFill"/>

            <BoxView Background="#661B3A6B"/>

            <VerticalStackLayout Padding="40"
                                 Spacing="16"
                                 VerticalOptions="Center">

                <Label Text="Reset Your Password"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="We’ll send you a link to reset your password securely."
                       TextColor="#E9EEF8"/>

            </VerticalStackLayout>
        </Grid>

        <!-- ===== RIGHT ===== -->
        <Grid Grid.Column="1" BackgroundColor="White">
            <ScrollView>
                <VerticalStackLayout Padding="40" Spacing="20"
                                     VerticalOptions="Center">

                    <Label Text="Forgot Password"
                           FontSize="28"
                           FontAttributes="Bold"/>

                    <Label Text="Enter your email to receive reset link"
                           TextColor="Gray"/>

                    <Border Stroke="#DDD"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                        <Entry Placeholder="Email address"
                               Keyboard="Email"/>
                    </Border>

                    <Button Text="Send Reset Link"
                            BackgroundColor="#1B3A6B"
                            TextColor="White"
                            CornerRadius="12"
                            Clicked="OnSendResetClicked"/>

                    <Button Text="Back to Login"
                            BackgroundColor="Transparent"
                            TextColor="#1B3A6B"
                            Clicked="OnBackClicked"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>