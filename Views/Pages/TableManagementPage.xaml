<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppManagermentRestaurant.Views.Pages.TableManagementPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AppManagermentRestaurant.Controls"
    xmlns:helpers="clr-namespace:AppManagermentRestaurant.Helpers"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <helpers:HasValueConverter x:Key="HasValueConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <controls:AppHeaderView />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="20">

                <Label Text="Sơ đồ bàn" Style="{StaticResource PageTitle}" />

                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="12">
                    <Border Style="{StaticResource CardBorder}" Background="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterColorConverter}, ConverterParameter='Available'}" Opacity="{Binding SelectedStatusFilter, Converter={StaticResource OpacityConverter}, ConverterParameter='Available'}">
                        <Border.Behaviors>
                            <toolkit:TouchBehavior PressedBackgroundColor="#E8F9E8" DefaultBackgroundColor="Transparent" PressedOpacity="0.8"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatusFilterTapped" CommandParameter="Available"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="✅ Còn trống" FontAttributes="Bold" FontSize="12.5"/>
                            <Label Text="{Binding AvailableCount}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                            <Label Text="bàn" FontSize="12" Style="{StaticResource MutedTextStyle}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Grid.Column="1" Background="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterColorConverter}, ConverterParameter='Occupied'}" Opacity="{Binding SelectedStatusFilter, Converter={StaticResource OpacityConverter}, ConverterParameter='Occupied'}">
                        <Border.Behaviors>
                            <toolkit:TouchBehavior PressedBackgroundColor="#FDE8E8" DefaultBackgroundColor="Transparent" PressedOpacity="0.8"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatusFilterTapped" CommandParameter="Occupied"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="👤 Có khách" FontAttributes="Bold" FontSize="12.5"/>
                            <Label Text="{Binding OccupiedCount}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Danger}"/>
                            <Label Text="bàn" FontSize="12" Style="{StaticResource MutedTextStyle}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Grid.Column="2" Background="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterColorConverter}, ConverterParameter='Ordered'}" Opacity="{Binding SelectedStatusFilter, Converter={StaticResource OpacityConverter}, ConverterParameter='Ordered'}">
                        <Border.Behaviors>
                            <toolkit:TouchBehavior PressedBackgroundColor="#EFF6FF" DefaultBackgroundColor="Transparent" PressedOpacity="0.8"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatusFilterTapped" CommandParameter="Ordered"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="🍲 Đã gọi món" FontAttributes="Bold" FontSize="12.5"/>
                            <Label Text="{Binding OrderedCount}" FontSize="24" FontAttributes="Bold" TextColor="#3B82F6"/>
                            <Label Text="bàn" FontSize="12" Style="{StaticResource MutedTextStyle}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Grid.Column="3" Background="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterColorConverter}, ConverterParameter='Reserved'}" Opacity="{Binding SelectedStatusFilter, Converter={StaticResource OpacityConverter}, ConverterParameter='Reserved'}">
                        <Border.Behaviors>
                            <toolkit:TouchBehavior PressedBackgroundColor="#FFFAE8" DefaultBackgroundColor="Transparent" PressedOpacity="0.8"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatusFilterTapped" CommandParameter="Reserved"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="🕒 Đặt trước" FontAttributes="Bold" FontSize="12.5"/>
                            <Label Text="{Binding ReservedCount}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Warning}"/>
                            <Label Text="bàn" FontSize="12" Style="{StaticResource MutedTextStyle}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Grid.Column="4" Background="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterColorConverter}, ConverterParameter='NeedsClearing'}" Opacity="{Binding SelectedStatusFilter, Converter={StaticResource OpacityConverter}, ConverterParameter='NeedsClearing'}">
                        <Border.Behaviors>
                            <toolkit:TouchBehavior PressedBackgroundColor="#E0E0E0" DefaultBackgroundColor="Transparent" PressedOpacity="0.8"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatusFilterTapped" CommandParameter="NeedsClearing"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="🧹 Cần dọn" FontAttributes="Bold" FontSize="12.5"/>
                            <Label Text="{Binding NeedsClearingCount}" FontSize="24" FontAttributes="Bold" TextColor="#888888"/>
                            <Label Text="bàn" FontSize="12" Style="{StaticResource MutedTextStyle}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource InputBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="🔍" VerticalOptions="Center" FontSize="16"/>
                        <Entry Grid.Column="1" Placeholder="Tìm kiếm bàn hoặc khu vực..." TextChanged="OnSearchTextChanged" x:Name="SearchEntry"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Chọn khu vực" FontSize="14" FontAttributes="Bold"/>
                        <ScrollView Orientation="Horizontal">
                            <HorizontalStackLayout Spacing="8">
                                <Button Text="📍 Tất cả" Style="{StaticResource PillButton}" Clicked="OnAreaFilterClicked" CommandParameter="All"/>
                                <Button Text="🏢 Tầng 1" Style="{StaticResource PillButton}" Clicked="OnAreaFilterClicked" CommandParameter="Ground Floor"/>
                                <Button Text="🏢 Tầng 2" Style="{StaticResource PillButton}" Clicked="OnAreaFilterClicked" CommandParameter="Second Floor"/>
                                <Button Text="🌳 Sân thượng" Style="{StaticResource PillButton}" Clicked="OnAreaFilterClicked" CommandParameter="Garden"/>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="16" IsVisible="{Binding HasFilteredTables}">

                    <VerticalStackLayout IsVisible="{Binding ShowGroundFloor}" Spacing="12">
                        <Label Text="🏢 Tầng 1" Style="{StaticResource SectionTitle}"/>
                        <CollectionView ItemsSource="{Binding FilteredGroundFloorTables}" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Surface}" Stroke="{Binding StatusColor}" StrokeThickness="4" StrokeShape="RoundRectangle 14" Padding="12,16" HeightRequest="160" Margin="0">
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                                            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding StatusIcon}" FontSize="18" VerticalOptions="Center" TextColor="{Binding StatusColor}"/>
                                                    <Label Text="{Binding DisplayNumber}" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" TextColor="#111827"/>
                                                    <Label Text="{Binding ReservationGuestName, StringFormat='- {0}'}" FontAttributes="Bold" FontSize="18" TextColor="#111827" IsVisible="{Binding IsReserved}"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsReserved}" VerticalOptions="Center">
                                                    <Label Text="🕒" FontSize="16" VerticalOptions="Center"/>
                                                    <Label Text="{Binding ReservationTime}" FontSize="16" FontAttributes="Bold" TextColor="#F59E0B" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                                <Label Text="👥" FontSize="16"/>
                                                <Label Text="{Binding Capacity, StringFormat='{0} chỗ'}" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                            </HorizontalStackLayout>
                                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="6" IsVisible="{Binding CanClearEmptyOccupied}">
                                                <Button Grid.Column="0" Text="📝 Gọi món" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnOrderTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="1" Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="2" Text="🧹 Làm trống" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnClearEmptyTableClicked" CommandParameter="{Binding .}"/>
                                            </Grid>
                                            <FlexLayout Grid.Row="2" Wrap="Wrap" Direction="Row" JustifyContent="End" AlignItems="Center" AlignContent="End" IsVisible="{Binding CanClearEmptyOccupied, Converter={StaticResource BoolNegationConverter}}">
                                                <Button Text="👤 Nhận khách" Style="{StaticResource PillButton}" BackgroundColor="#DCFCE7" TextColor="#16A34A" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsAvailable}" Clicked="OnReceiveGuestClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✅ Nhận bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEF3C7" TextColor="#D97706" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsReserved}" Clicked="OnCheckInTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#DBEAFE" TextColor="#2563EB" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="💳 Thanh toán" Style="{StaticResource PillButton}" BackgroundColor="#3B82F6" TextColor="White" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnPayTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✨ Dọn dẹp" Style="{StaticResource PillButton}" BackgroundColor="#F3F4F6" TextColor="#4B5563" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsNeedsClearing}" Clicked="OnCleanTableClicked" CommandParameter="{Binding .}"/>
                                            </FlexLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowSecondFloor}" Spacing="12">
                        <Label Text="🏢 Tầng 2" Style="{StaticResource SectionTitle}"/>
                        <CollectionView ItemsSource="{Binding FilteredSecondFloorTables}" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Surface}" Stroke="{Binding StatusColor}" StrokeThickness="4" StrokeShape="RoundRectangle 14" Padding="12,16" HeightRequest="160" Margin="0">
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                                            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding StatusIcon}" FontSize="18" VerticalOptions="Center" TextColor="{Binding StatusColor}"/>
                                                    <Label Text="{Binding DisplayNumber}" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" TextColor="#111827"/>
                                                    <Label Text="{Binding ReservationGuestName, StringFormat='- {0}'}" FontAttributes="Bold" FontSize="18" TextColor="#111827" IsVisible="{Binding IsReserved}"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsReserved}" VerticalOptions="Center">
                                                    <Label Text="🕒" FontSize="16" VerticalOptions="Center"/>
                                                    <Label Text="{Binding ReservationTime}" FontSize="16" FontAttributes="Bold" TextColor="#F59E0B" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                                <Label Text="👥" FontSize="16"/>
                                                <Label Text="{Binding Capacity, StringFormat='{0} chỗ'}" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                            </HorizontalStackLayout>
                                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="6" IsVisible="{Binding CanClearEmptyOccupied}">
                                                <Button Grid.Column="0" Text="📝 Gọi món" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnOrderTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="1" Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="2" Text="🧹 Làm trống" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnClearEmptyTableClicked" CommandParameter="{Binding .}"/>
                                            </Grid>
                                            <FlexLayout Grid.Row="2" Wrap="Wrap" Direction="Row" JustifyContent="End" AlignItems="Center" AlignContent="End" IsVisible="{Binding CanClearEmptyOccupied, Converter={StaticResource BoolNegationConverter}}">
                                                <Button Text="👤 Nhận khách" Style="{StaticResource PillButton}" BackgroundColor="#DCFCE7" TextColor="#16A34A" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsAvailable}" Clicked="OnReceiveGuestClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✅ Nhận bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEF3C7" TextColor="#D97706" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsReserved}" Clicked="OnCheckInTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#DBEAFE" TextColor="#2563EB" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="💳 Thanh toán" Style="{StaticResource PillButton}" BackgroundColor="#3B82F6" TextColor="White" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnPayTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✨ Dọn dẹp" Style="{StaticResource PillButton}" BackgroundColor="#F3F4F6" TextColor="#4B5563" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsNeedsClearing}" Clicked="OnCleanTableClicked" CommandParameter="{Binding .}"/>
                                            </FlexLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowGarden}" Spacing="12">
                        <Label Text="🌳 Sân thượng" Style="{StaticResource SectionTitle}"/>
                        <CollectionView ItemsSource="{Binding FilteredGardenTables}" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Surface}" Stroke="{Binding StatusColor}" StrokeThickness="4" StrokeShape="RoundRectangle 14" Padding="12,16" HeightRequest="160" Margin="0">
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                                            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding StatusIcon}" FontSize="18" VerticalOptions="Center" TextColor="{Binding StatusColor}"/>
                                                    <Label Text="{Binding DisplayNumber}" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" TextColor="#111827"/>
                                                    <Label Text="{Binding ReservationGuestName, StringFormat='- {0}'}" FontAttributes="Bold" FontSize="18" TextColor="#111827" IsVisible="{Binding IsReserved}"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsReserved}" VerticalOptions="Center">
                                                    <Label Text="🕒" FontSize="16" VerticalOptions="Center"/>
                                                    <Label Text="{Binding ReservationTime}" FontSize="16" FontAttributes="Bold" TextColor="#F59E0B" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                                <Label Text="👥" FontSize="16"/>
                                                <Label Text="{Binding Capacity, StringFormat='{0} chỗ'}" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                            </HorizontalStackLayout>
                                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="6" IsVisible="{Binding CanClearEmptyOccupied}">
                                                <Button Grid.Column="0" Text="📝 Gọi món" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnOrderTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="1" Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Grid.Column="2" Text="🧹 Làm trống" Style="{StaticResource PillButton}" BackgroundColor="#FEE2E2" TextColor="#DC2626" Padding="0" FontSize="11.5" HeightRequest="34" Clicked="OnClearEmptyTableClicked" CommandParameter="{Binding .}"/>
                                            </Grid>
                                            <FlexLayout Grid.Row="2" Wrap="Wrap" Direction="Row" JustifyContent="End" AlignItems="Center" AlignContent="End" IsVisible="{Binding CanClearEmptyOccupied, Converter={StaticResource BoolNegationConverter}}">
                                                <Button Text="👤 Nhận khách" Style="{StaticResource PillButton}" BackgroundColor="#DCFCE7" TextColor="#16A34A" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsAvailable}" Clicked="OnReceiveGuestClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✅ Nhận bàn" Style="{StaticResource PillButton}" BackgroundColor="#FEF3C7" TextColor="#D97706" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsReserved}" Clicked="OnCheckInTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="🔄 Đổi bàn" Style="{StaticResource PillButton}" BackgroundColor="#DBEAFE" TextColor="#2563EB" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnChangeTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="💳 Thanh toán" Style="{StaticResource PillButton}" BackgroundColor="#3B82F6" TextColor="White" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding CanPayOccupied}" Clicked="OnPayTableClicked" CommandParameter="{Binding .}"/>
                                                <Button Text="✨ Dọn dẹp" Style="{StaticResource PillButton}" BackgroundColor="#F3F4F6" TextColor="#4B5563" Padding="10,0" FontSize="11.5" HeightRequest="34" Margin="0,0,6,0" IsVisible="{Binding IsNeedsClearing}" Clicked="OnCleanTableClicked" CommandParameter="{Binding .}"/>
                                            </FlexLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12" IsVisible="{Binding HasFilteredTables, Converter={StaticResource BoolNegationConverter}}" HorizontalOptions="Center" VerticalOptions="Center" Padding="20">
                    <Label Text="😕 Không tìm thấy bàn nào" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Thử thay đổi bộ lọc hoặc tìm kiếm lại" Style="{StaticResource MutedTextStyle}" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>