<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Class="AppManagermentRestaurant.Views.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="*,*">

        <!-- Loading Overlay -->
        <Grid Grid.ColumnSpan="2" 
              IsVisible="{Binding IsLoading}" 
              BackgroundColor="#CC000000"
              ZIndex="100">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                   Color="White" 
                                   Scale="2" />
                <Label Text="Signing in..." 
                       TextColor="White" 
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- ===== LEFT SIDE ===== -->
        <Grid Grid.Column="0" IsVisible="{OnIdiom Phone=False, Default=True}">

            <!-- Background -->
            <Image Source="anhnenlogin.jpg"
                   Aspect="AspectFill"/>

            <!-- Overlay -->
            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#661B3A6B" Offset="0"/>
                        <GradientStop Color="#221B3A6B" Offset="1"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Content (CENTER) -->
            <VerticalStackLayout Padding="40"
                                 Spacing="16"
                                 VerticalOptions="Center">

                <HorizontalStackLayout Spacing="10">
                    <Border Background="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="10,5">
                        <Label Text="Chef"
                               TextColor="#1B3A6B"
                               FontAttributes="Bold"/>
                    </Border>

                    <Label Text="Classic Restaurant"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </HorizontalStackLayout>

                <Label Text="Elevating Every Dining Experience"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="White"
                       LineBreakMode="WordWrap"/>

                <Label Text="A refined dining OS for teams who serve with precision and warmth."
                       FontSize="15"
                       TextColor="#E9EEF8"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ===== RIGHT SIDE ===== -->
        <Grid Grid.Column="1" BackgroundColor="White">
            <ScrollView>
                <VerticalStackLayout Padding="40" Spacing="20">

                    <Label Text="Welcome back"
                           FontSize="28"
                           FontAttributes="Bold"/>

                    <!-- Quick Access Buttons -->
                    <HorizontalStackLayout Spacing="10" Margin="0,10">
                        <Button Text="Staff"
                                Background="#1B3A6B"
                                TextColor="White"
                                CornerRadius="8"
                                HorizontalOptions="FillAndExpand"
                                Clicked="OnSelectStaffRole"/>
                        <Button Text="Manager"
                                Background="#1B3A6B"
                                TextColor="White"
                                CornerRadius="8"
                                HorizontalOptions="FillAndExpand"
                                Clicked="OnSelectManagerRole"/>
                    </HorizontalStackLayout>

                    <!-- Email -->
                    <Border Stroke="#DDD" StrokeShape="RoundRectangle 12" Padding="12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="✉" TextColor="#777" FontSize="18"/>
                            <Entry Grid.Column="1" 
                                   Text="{Binding Email}" 
                                   Placeholder="Email address"
                                   IsEnabled="{Binding IsLoading, Converter={StaticResource BooleanNegationConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#EF4444"
                           FontSize="13"
                           IsVisible="{Binding HasError}"
                           Margin="0,-10,0,0"/>

                    <Button Text="Forgot password?"
                            BackgroundColor="Transparent"
                            TextColor="#1B3A6B"
                            FontAttributes="Bold"
                            HorizontalOptions="Start"
                            Clicked="OnForgotPasswordTapped"/>  

                    <Button Text="Sign In"
                            BackgroundColor="#1B3A6B"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource BooleanNegationConverter}}"
                            Clicked="OnSignInClicked"/>

                    <!-- Demo -->
                    <Border Background="#F3EEE8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="16">
                        <VerticalStackLayout>
                            <Label Text="Demo accounts" FontAttributes="Bold"/>
                            <Label Text="Staff: tuan.staff@goldenplate.vn"/>
                            <Label Text="Manager: quan.manager@goldenplate.vn"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>