<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppManagermentRestaurant.Views.Pages.NotificationsManagementPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AppManagermentRestaurant.Controls"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*" ColumnSpacing="20">
        <controls:AppHeaderView Grid.ColumnSpan="2" />

        <ScrollView Grid.Row="1" Grid.Column="0">
            <VerticalStackLayout Padding="24" Spacing="20">
                <Label Text="Send Notification" Style="{StaticResource PageTitle}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Type" FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Info" Style="{StaticResource PillButton}" />
                            <Button Text="Warning" Style="{StaticResource PillButton}" />
                            <Button Text="Success" Style="{StaticResource PillButton}" />
                        </HorizontalStackLayout>

                        <Border Style="{StaticResource InputBorder}">
                            <Entry Placeholder="Title" />
                        </Border>

                        <Border Style="{StaticResource InputBorder}">
                            <Editor Placeholder="Message" AutoSize="TextChanges" />
                        </Border>

                        <Border Style="{StaticResource InputBorder}">
                            <Label Text="Will be sent to: All active staff members (3)" Style="{StaticResource SecondaryTextStyle}" />
                        </Border>

                        <Button Text="Send to All Staff" Style="{StaticResource PrimaryButton}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="1" Grid.Column="1">
            <VerticalStackLayout Padding="24" Spacing="20">
                <Label Text="Recent Notifications" Style="{StaticResource PageTitle}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <CollectionView ItemsSource="{Binding Notifications}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource InputBorder}" Padding="12" Margin="0,0,0,8">
                                        <HorizontalStackLayout Spacing="8">
                                            <Border Background="{Binding TypeColor}" Stroke="{Binding TypeColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="6">
                                                <Label Text="{Binding TypeLabel}" TextColor="White" FontSize="10" />
                                            </Border>
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                                <Label Text="{Binding Message}" Style="{StaticResource SecondaryTextStyle}" FontSize="12" />
                                                <Label Text="{Binding TimestampDisplay}" Style="{StaticResource MutedTextStyle}" FontSize="11" />
                                            </VerticalStackLayout>
                                            <Button Text="X" Style="{StaticResource SecondaryButton}" HorizontalOptions="EndAndExpand" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

