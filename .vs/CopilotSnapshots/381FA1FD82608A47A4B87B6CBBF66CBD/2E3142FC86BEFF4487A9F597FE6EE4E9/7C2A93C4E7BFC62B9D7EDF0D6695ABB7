<?xml version="1.0" encoding="utf-8" ?>
<!--
    ChatPopup.xaml

    THAY ĐỔI: Đã xoá HorizontalOptions="End" VerticalOptions="Start" (sai mục đích).
    Vị trí bên dưới nút chat được xử lý bởi Anchor trong AppHeaderView.xaml.cs.
    Dim được xử lý bởi NoDimPopupHandler.cs.
-->
<toolkit:Popup
    x:Class="AppManagermentRestaurant.Controls.Popups.ChatPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Color="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        BackgroundColor="#FDFAF6"
        Stroke="#E7DECF"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 16"
        Padding="0"
        WidthRequest="384"
        HeightRequest="480"
        Shadow="{Shadow Brush=Black, Offset='0,8', Radius=20, Opacity=0.18}">

        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

            <!-- Header xanh navy -->
            <Grid
                Grid.Row="0"
                Padding="12"
                ColumnDefinitions="*,Auto"
                BackgroundColor="#1B3A6B">
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="💬" FontSize="16" TextColor="White" />
                    <Label Text="Chat nội bộ" FontSize="14" FontAttributes="Bold" TextColor="White" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Label Text="●" FontSize="10" TextColor="#22C55E" VerticalTextAlignment="Center" />
                    <Label
                        Text="{Binding OnlineCount, StringFormat='{0} online'}"
                        FontSize="11"
                        TextColor="#E2E8F0"
                        VerticalTextAlignment="Center" />
                    <Button
                        Text="Mở rộng"
                        FontSize="10"
                        TextColor="White"
                        BackgroundColor="#26FFFFFF"
                        CornerRadius="8"
                        Padding="8,4"
                        Command="{Binding OpenExpandedChatCommand}" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Danh sách tin nhắn -->
            <CollectionView
                x:Name="PopupChatList"
                Grid.Row="1"
                ItemsSource="{Binding ChatMessages}"
                SelectionMode="None"
                ItemsUpdatingScrollMode="KeepLastItemInView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="12,6" Spacing="6">

                            <!-- Tin hệ thống -->
                            <Border
                                IsVisible="{Binding IsSystem}"
                                HorizontalOptions="Center"
                                BackgroundColor="#1A4A90D9"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,6">
                                <Label
                                    Text="{Binding Message, StringFormat='🔔 {0}'}"
                                    FontSize="11"
                                    TextColor="#1B3A6B" />
                            </Border>

                            <!-- Tin của người khác (bên trái) -->
                            <HorizontalStackLayout
                                IsVisible="{Binding IsMine, Converter={StaticResource BooleanNegationConverter}}"
                                Spacing="8"
                                VerticalOptions="Start">
                                <Border
                                    WidthRequest="28" HeightRequest="28"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{Binding AvatarBackgroundColor}"
                                    VerticalOptions="End">
                                    <Label
                                        Text="{Binding SenderInitial}"
                                        FontSize="12" FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding SenderName}" FontSize="11" FontAttributes="Bold" TextColor="#4A3B2E" />
                                    <Border BackgroundColor="#EDE8DC" StrokeThickness="0" StrokeShape="RoundRectangle 16,16,16,4" Padding="12,8">
                                        <Label Text="{Binding Message}" FontSize="13" LineHeight="1.4" TextColor="#1A1209" />
                                    </Border>
                                    <Label Text="{Binding TimestampDisplay}" FontSize="10" TextColor="#C5B8A8" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <!-- Tin của mình (bên phải) -->
                            <HorizontalStackLayout
                                IsVisible="{Binding IsMine}"
                                Spacing="8"
                                HorizontalOptions="End"
                                VerticalOptions="Start">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="End">
                                    <Border BackgroundColor="#1B3A6B" StrokeThickness="0" StrokeShape="RoundRectangle 16,16,4,16" Padding="12,8" HorizontalOptions="End">
                                        <Label Text="{Binding Message}" FontSize="13" LineHeight="1.4" TextColor="White" />
                                    </Border>
                                    <Label Text="{Binding TimestampDisplay}" FontSize="10" TextColor="#C5B8A8" HorizontalTextAlignment="End" />
                                </VerticalStackLayout>
                                <Border
                                    WidthRequest="28" HeightRequest="28"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{Binding AvatarBackgroundColor}"
                                    VerticalOptions="End">
                                    <Label
                                        Text="{Binding SenderInitial}"
                                        FontSize="12" FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Input gửi tin nhắn -->
            <Grid
                Grid.Row="2"
                Padding="12"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="8"
                BackgroundColor="#FDFAF6">
                <Border BackgroundColor="#EDE8DC" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,8">
                    <Entry
                        x:Name="ChatEntryField"
                        Text="{Binding ChatInput, Mode=TwoWay}"
                        Placeholder="Nhập tin nhắn..."
                        FontSize="13"
                        ReturnType="Send"
                        Completed="OnChatEntryCompleted" />
                </Border>
                <Button
                    Grid.Column="1"
                    Text="➤"
                    WidthRequest="36" HeightRequest="36"
                    CornerRadius="12"
                    FontSize="16"
                    TextColor="White"
                    Command="{Binding SendChatMessageCommand}"
                    IsEnabled="{Binding CanSendChat}"
                    Clicked="OnSendClicked">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding CanSendChat}" Value="True">
                            <Setter Property="BackgroundColor" Value="#1B3A6B" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding CanSendChat}" Value="False">
                            <Setter Property="BackgroundColor" Value="#C5B8A8" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

        </Grid>
    </Border>
</toolkit:Popup>
