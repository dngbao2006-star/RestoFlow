<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Inter: font trung tính cho toàn bộ UI thao tác (bảng biểu, menu, báo cáo) -->
    <x:String x:Key="BodyFont">Inter</x:String>
    <!-- Playfair Display: chỉ dùng cho Logo và Tiêu đề lớn (sang trọng) -->
    <x:String x:Key="DisplayFont">Playfair Display</x:String>

    <x:Double x:Key="RadiusSm">8</x:Double>
    <x:Double x:Key="RadiusMd">12</x:Double>
    <x:Double x:Key="RadiusLg">16</x:Double>
    <x:Double x:Key="RadiusFull">999</x:Double>

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Label" x:Key="PageTitle">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="SectionTitle">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="MutedTextStyle">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="11.5" />
    </Style>

    <Style TargetType="Label" x:Key="SecondaryTextStyle">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="TextColor" Value="#4A3B2E" />
        <Setter Property="BackgroundColor" Value="{StaticResource SecondarySurface}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style TargetType="Button" x:Key="DangerButton">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="BackgroundColor" Value="#FDE8E8" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style TargetType="Button" x:Key="PillButton">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SecondarySurface}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusLg}" />
        </Setter>
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style TargetType="Border" x:Key="InputBorder">
        <Setter Property="Background" Value="{StaticResource SecondarySurface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderStrong}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14.4" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14.4" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Border" x:Key="BadgeBorder">
        <Setter Property="Background" Value="{StaticResource SecondarySurface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusFull}" />
        </Setter>
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="Label" x:Key="BadgeText">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Additional custom styles for consistent typography -->
    <Style TargetType="Label" x:Key="TinyLabel">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="10.9" />
    </Style>

    <!-- Success Button Style -->
    <Style TargetType="Button" x:Key="SuccessButton">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <!-- Warning Button Style -->
    <Style TargetType="Button" x:Key="WarningButton">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <!-- Ghost Button (Text only) -->
    <Style TargetType="Button" x:Key="GhostButton">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- Icon Button Style -->
    <Style TargetType="Button" x:Key="IconButton">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SecondarySurface}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Modal Card for Dialogs -->
    <Style TargetType="Border" x:Key="ModalBorder">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="20" />
        </Setter>
        <Setter Property="Padding" Value="24" />
    </Style>

    <!-- Error State Style -->
    <Style TargetType="Border" x:Key="ErrorBorder">
        <Setter Property="Background" Value="#FDE8E8" />
        <Setter Property="Stroke" Value="{StaticResource Danger}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Success State Style -->
    <Style TargetType="Border" x:Key="SuccessBorder">
        <Setter Property="Background" Value="#E8F9E8" />
        <Setter Property="Stroke" Value="{StaticResource Success}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Info State Style -->
    <Style TargetType="Border" x:Key="InfoBorder">
        <Setter Property="Background" Value="#E8F3FD" />
        <Setter Property="Stroke" Value="{StaticResource Info}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Warning State Style -->
    <Style TargetType="Border" x:Key="WarningBorder">
        <Setter Property="Background" Value="#FFFAE8" />
        <Setter Property="Stroke" Value="{StaticResource Warning}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Table Tag Style -->
    <Style TargetType="Border" x:Key="TableTagBorder">
        <Setter Property="Background" Value="{StaticResource SecondarySurface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="{StaticResource RadiusMd}" />
        </Setter>
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- Empty State Text -->
    <Style TargetType="Label" x:Key="EmptyStateLabel">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SmallLabel">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <Style TargetType="Label" x:Key="BodySmall">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="13.6" />
    </Style>

    <Style TargetType="Label" x:Key="SubtitleLarge">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="17.6" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="TitleSmall">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMuted}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextMuted}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextMuted}}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondary}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
    </Style>

    <!-- Converters -->
    <x:Double x:Key="OpacityOutOfStock">0.6</x:Double>
    <x:Double x:Key="OpacityInStock">1.0</x:Double>

</ResourceDictionary>

