<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuanAnApp.MainPage">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="THỰC ĐƠN QUÁN ĂN" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="DarkBlue" />

        <Button Text="Tải dữ liệu từ Backend" Clicked="OnLoadDataClicked" BackgroundColor="#2196F3" TextColor="White" CornerRadius="10" />

        <CollectionView x:Name="MenuListView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" BorderColor="LightGray" CornerRadius="8">
                        <HorizontalStackLayout Spacing="15">
                            <Label Text="{Binding TenMon}" FontAttributes="Bold" FontSize="18" WidthRequest="200" VerticalOptions="Center" />
                            <Label Text="{Binding Gia, StringFormat='{0:N0} VNĐ'}" TextColor="Red" FontSize="18" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
